APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

COMPANY_NAME="LeafLight Client"
COMPANY_LEGAL_NAME=
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_PHONE_SALES=
COMPANY_PHONE_OFFICE=
COMPANY_EMAIL=
COMPANY_EMAIL_SALES=
COMPANY_TIN=
COMPANY_VAT_REG=
COMPANY_VENDOR_NUMBER=
COMPANY_BANK_NAME=
COMPANY_BANK_ACCOUNT_NAME=
COMPANY_BANK_ACCOUNT_NUMBER=

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── ZIMRA FDMS ────────────────────────────────────────────
ZIMRA_API_URL=https://fdmsapitest.zimra.co.zw
ZIMRA_QR_BASE_URL=https://fdmstest.zimra.co.zw
ZIMRA_CERT_FILE=certs/fiscal_device.p12
ZIMRA_CERT_PASSWORD=
ZIMRA_RECEIPT_TIMEZONE=Africa/Harare

# ── Paynow Zimbabwe ───────────────────────────────────────
PAYNOW_MERCHANT_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RESULT_URL="${APP_URL}/api/v1/eft/paynow/callback"
PAYNOW_RETURN_URL="${APP_URL}/payment/complete"
PAYNOW_EXPIRY_MINUTES=30

# ── EFT / ZimSwitch Card Payments ─────────────────────────
EFT_DEFAULT_CHANNEL=terminal

# Physical POS terminal (PAX ECR over TCP — default port 10009)
EFT_TERMINAL_IP=127.0.0.1
EFT_TERMINAL_PORT=10009
EFT_TERMINAL_TIMEOUT=90

# Online payments (bank-hosted page via ZimSwitch)
EFT_ONLINE_MERCHANT_ID=
EFT_ONLINE_API_KEY=
EFT_ONLINE_API_URL=https://payments.bank.co.zw/api/v1
EFT_ONLINE_CALLBACK_URL="${APP_URL}/api/v1/eft/callback"
EFT_ONLINE_RETURN_URL="${APP_URL}/payment/complete"
EFT_ONLINE_EXPIRY_MINUTES=15

# ── Client / Company Identity ──────────────────────────────
COMPANY_NAME="LeafLight Client"
COMPANY_LEGAL_NAME="LeafLight Client (Pvt) Ltd"
COMPANY_ADDRESS="123 Example Street, City"
COMPANY_PHONE=""
COMPANY_TIN=""
COMPANY_VAT_REG=""
COMPANY_EMAIL=""
